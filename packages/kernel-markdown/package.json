{
  "name": "@website-kernel/markdown",
  "version": "1.0.0",
  "author": "chentao.arthur",
  "scripts": {
    "dev": "tsdown --config ./tsdown.config.ts --watch",
    "build": "rimraf dist && tsdown --config ./tsdown.config.ts && infra build-css",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "imports": {
    "#index": "./src/index.js",
    "#markdown/*.css": "./src/*.css",
    "#markdown/*": "./src/*.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    },
    "./es/*": "./dist/es/*",
    "./lib/*": "./dist/lib/*",
    "./style.css": "./dist/index.css"
  },
  "main": "./dist/lib/index.js",
  "module": "./dist/es/index.js",
  "unpkg": "./dist/index.global.js",
  "types": "./dist/es/index.d.ts",
  "files": ["dist"],
  "sideEffects": ["**/*.css"],
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-icons": "catalog:",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "react-twitter-widgets": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@website/infra": "workspace:*",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
