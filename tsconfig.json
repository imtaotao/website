{
  "exclude": ["scripts"],
  "compilerOptions": {
    "target": "ES2018",
    "module": "preserve",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowJs": false,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "forceConsistentCasingInFileNames": true,
    "pretty": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "moduleResolution": "Bundler",
    "skipDefaultLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "strictPropertyInitialization": false,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "declaration": true,
    "sourceMap": false,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "paths": {
      // app
      "#app/*": ["./app/src/*"],

      // externals
      "auklet": ["./auklet/src/index.ts"],
      "auklet/*": ["./auklet/src/*"],

      // workspace package root imports
      "@website-kernel/*": ["./packages/kernel-*/src"],

      // workspace package component subpath imports
      "@website-kernel/blog/*": [
        "./packages/kernel-blog/src/*/index.tsx",
        "./packages/kernel-blog/src/*.tsx"
      ],
      "@website-kernel/resume/*": [
        "./packages/kernel-resume/src/*/index.tsx",
        "./packages/kernel-resume/src/*.tsx"
      ],
      "@website-kernel/shared/*": [
        "./packages/kernel-shared/src/*/index.tsx",
        "./packages/kernel-shared/src/*.tsx"
      ],
      "@website-kernel/markdown/*": [
        "./packages/kernel-markdown/src/*/index.tsx",
        "./packages/kernel-markdown/src/*.tsx"
      ],

      // internal package aliases
      "#auklet/*": ["./auklet/src/*"],
      "#blog/*": ["./packages/kernel-blog/src/*"],
      "#resume/*": ["./packages/kernel-resume/src/*"],
      "#shared/*": ["./packages/kernel-shared/src/*"],
      "#markdown/*": ["./packages/kernel-markdown/src/*"],
    }
  }
}
