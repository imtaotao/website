{
  "name": "website",
  "version": "1.0.0",
  "author": "chentao.arthur",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @website/app run dev",
    "build": "pnpm --filter @website/app run build",
    "preview": "pnpm --filter @website/app run preview",
    "dev:packages": "pnpm --parallel --filter @website-kernel/* run dev",
    "build:packages": "pnpm --parallel --filter @website-kernel/* run build",
    "format": "prettier --write --parser typescript \"(app|packages)/**/*.(t|j)s?(x)\""
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/minimist": "^1.2.5",
    "typescript": "catalog:",
    "tsx": "^4.11.2",
    "execa": "^9.1.0",
    "husky": "^9.0.11",
    "prettier": "^2.4.1",
    "minimist": "^1.2.8",
    "lint-staged": "^15.2.5",
    "esbuild-plugin-replace": "^1.4.0"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22",
    "pnpm": "=10.27.0"
  }
}
