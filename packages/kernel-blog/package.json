{
  "name": "@website-kernel/blog",
  "version": "1.0.0",
  "author": "chentao.arthur",
  "scripts": {
    "dev": "tsdown --watch & infra build-css --watch",
    "build": "rimraf dist && tsdown && infra build-css",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "imports": {
    "#index": "./src/index.js",
    "#blog/*.css": "./src/*.css",
    "#blog/*": "./src/*.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/es/*/index.d.ts",
        "default": "./dist/es/*/index.js"
      },
      "require": {
        "types": "./dist/lib/*/index.d.ts",
        "default": "./dist/lib/*/index.js"
      }
    },
    "./*.css": {
      "import": "./dist/es/*/style/index.css",
      "require": "./dist/lib/*/style/index.css",
      "default": "./dist/es/*/style/index.css"
    },
    "./style.css": {
      "import": "./dist/es/style/index.css",
      "require": "./dist/lib/style/index.css",
      "default": "./dist/es/style/index.css"
    },
    "./themes/*.css": {
      "import": "./dist/es/themes/*.css",
      "require": "./dist/lib/themes/*.css",
      "default": "./dist/es/themes/*.css"
    },
    "./external.css": {
      "import": "./dist/es/style/external.css",
      "require": "./dist/lib/style/external.css",
      "default": "./dist/es/style/external.css"
    }
  },
  "main": "./dist/lib/index.js",
  "module": "./dist/es/index.js",
  "unpkg": "./dist/index.global.js",
  "types": "./dist/es/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@website-kernel/markdown": "workspace:*",
    "@radix-ui/react-icons": "catalog:",
    "aidly": "catalog:",
    "yaml": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-router": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@website/infra": "workspace:*",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "rimraf": "catalog:",
    "vitest": "catalog:",
    "typescript": "catalog:"
  }
}
