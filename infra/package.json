{
  "name": "@website/infra",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "chentao.arthur",
  "bin": {
    "infra": "./bin/entry.cjs"
  },
  "exports": {
    "./css": "./css.mjs",
    "./css/config": {
      "types": "./css-config.d.cts",
      "default": "./css-config.cjs"
    }
  },
  "imports": {
    "#infra/*": "./src/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@types/node": "catalog:",
    "@types/minimist": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsx": "catalog:",
    "execa": "catalog:",
    "aidly": "catalog:",
    "postcss": "catalog:",
    "chokidar": "catalog:",
    "minimist": "catalog:",
    "typescript": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
