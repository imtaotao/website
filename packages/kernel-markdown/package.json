{
  "name": "@website-kernel/markdown",
  "version": "1.0.0",
  "author": "chentao.arthur",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rimraf dist && tsdown && infra build-css",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "imports": {
    "#index": "./src/index.js",
    "#markdown/*.css": "./src/*.css",
    "#markdown/*": "./src/*.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/lib/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/es/*/index.d.ts",
        "default": "./dist/es/*/index.js"
      },
      "require": {
        "types": "./dist/lib/*/index.d.ts",
        "default": "./dist/lib/*/index.js"
      }
    },
    "./*.css": {
      "import": "./dist/es/*/style/index.css",
      "require": "./dist/lib/*/style/index.css",
      "default": "./dist/es/*/style/index.css"
    },
    "./style.css": {
      "import": "./dist/es/style/index.css",
      "require": "./dist/lib/style/index.css",
      "default": "./dist/es/style/index.css"
    },
    "./external.css": {
      "import": "./dist/es/style/external.css",
      "require": "./dist/lib/style/external.css",
      "default": "./dist/es/style/external.css"
    }
  },
  "main": "./dist/lib/index.js",
  "module": "./dist/es/index.js",
  "unpkg": "./dist/index.global.js",
  "types": "./dist/es/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-icons": "catalog:",
    "aidly": "catalog:",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "react-twitter-widgets": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@website/infra": "workspace:*",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
