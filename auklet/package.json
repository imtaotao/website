{
  "name": "auklet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "chentao.arthur",
  "bin": {
    "auk": "./bin/entry.cjs",
    "auklet": "./bin/entry.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#auklet/*": {
      "source": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "files": ["bin", "dist"],
  "dependencies": {
    "@types/node": "catalog:",
    "@types/minimist": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "execa": "catalog:",
    "aidly": "catalog:",
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "postcss": "catalog:",
    "chokidar": "catalog:",
    "minimist": "catalog:",
    "typescript": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
