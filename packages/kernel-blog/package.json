{
  "name": "@website-kernel/blog",
  "version": "1.0.0",
  "author": "chentao.arthur",
  "scripts": {
    "dev": "tsup --watch",
    "build": "rimraf dist && tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "imports": {
    "#index": "./src/index.js",
    "#blog/*.css": "./src/*.css",
    "#blog/*": "./src/*.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "node": "./dist/index.mjs",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-icons": "catalog:",
    "yaml": "catalog:",
    "aidly": "catalog:",
    "katex": "^0.16.45",
    "highlight.js": "^11.11.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "rimraf": "catalog:",
    "vitest": "catalog:",
    "typescript": "catalog:"
  }
}
