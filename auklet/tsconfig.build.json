{
  "extends": "../tsconfig.json",
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/__tests__/**"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "noEmitOnError": true
  }
}
